# Docker Compose publishes the web app to the trusted LAN by default.
# Set this to 127.0.0.1 to restore host-only access.
APP_BIND=0.0.0.0

# Local Python development (Docker Compose overrides the URL/network values).
OCR_BASE_URL=http://localhost:3111/v1
OCR_MANAGE_CONTAINER=true
OCR_DOCKER_NETWORK=
OCR_DOCKER_HOST_PORT=3111
OCR_GPU_MEMORY_UTILIZATION=0.85
OCR_MAX_MODEL_LEN=32768
# Optional: raises Hub rate limits. Never commit a real token.
OCR_HF_TOKEN=
OCR_HF_XET_HIGH_PERFORMANCE=true

# Processing limits and performance defaults.
OCR_MAX_UPLOAD_MB=100
OCR_MAX_BATCH_FILES=25
OCR_MAX_BATCH_UPLOAD_MB=500
OCR_MAX_PAGES=200
OCR_MAX_RENDER_MEGAPIXELS=50
OCR_DEFAULT_DPI=200
OCR_DEFAULT_PAGE_CONCURRENCY=2
OCR_MAX_PAGE_CONCURRENCY=4
OCR_DEFAULT_MAX_TOKENS=8192
OCR_JOB_RETENTION_HOURS=24
